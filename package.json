{
  "name": "enirman-ui",
  "version": "0.1.0",
  "description": "Shared design system and Vue component library for all eNirman apps",
  "main": "src/index.js",
  "module": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./theme.css": "./src/theme.css",
    "./tailwind-preset": "./tailwind-preset.js",
    "./components/*": "./src/components/*.vue",
    "./layouts/*": "./src/layouts/*.vue",
    "./composables/*": "./src/composables/*.js"
  },
  "files": [
    "src",
    "tailwind-preset.js",
    "docs"
  ],
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.0.0",
    "frappe-ui": "*",
    "@vueuse/core": "^10.0.0 || ^11.0.0 || ^12.0.0 || ^13.0.0 || ^14.0.0",
    "tailwindcss": "^3.4.0"
  },
  "keywords": ["enirman", "design-system", "vue", "frappe-ui"],
  "private": true
}
